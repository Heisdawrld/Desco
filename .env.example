# ═══════════════════════════════════════════════════════════════════════════
# DESCO 2.0 — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════════════
# Copy these into Netlify: Site settings → Environment variables.
# Do NOT commit a real .env file with secrets to git.
# ═══════════════════════════════════════════════════════════════════════════

# ── DATABASE (Turso / libSQL) ────────────────────────────────────────────────
# Get these from https://app.turso.tech → your DB → Settings
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# ── ADMIN AUTH ───────────────────────────────────────────────────────────────
# Strong password for the admin dashboard at /admin
# REQUIRED in production — the API will refuse to start without it.
ADMIN_PASSWORD=change-me-to-something-long-and-random

# ── CORS (which sites can call the API) ──────────────────────────────────────
# Comma-separated. Include both apex and www if you use both.
CORS_ALLOWED_ORIGINS=https://ulsesadesco.online,https://www.ulsesadesco.online

# ── EMAIL (Resend) ───────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address. MUST be a verified sender in Resend.
# Until you verify your domain, use the sandbox sender (only delivers to the
# account owner):
MAIL_FROM=DESCO 2.0 <onboarding@resend.dev>
#
# AFTER you verify ulsesadesco.online in Resend, switch to:
# MAIL_FROM=DESCO 2.0 <no-reply@ulsesadesco.online>

# Where admin notification emails go (new registration alerts).
ADMIN_NOTIFY_EMAIL=davidchuks229@gmail.com

# Reply-To address shown in outgoing emails.
REPLY_TO_EMAIL=desco@ulsesa.unilag.edu.ng

# ── EVENT DETAILS (shown in confirmation emails) ─────────────────────────────
EVENT_DATE_LONG=Friday, July 17, 2026
EVENT_TIME_LONG=9:00 AM (WAT)
EVENT_VENUE=Science Education Department, Faculty of Education, University of Lagos, Akoka

# WhatsApp number for student questions (include country code).
# Replace with the REAL number the organizing team will monitor.
WHATSAPP_NUMBER=+234 801 234 5678
# Optional: direct wa.me link if you have a dedicated click-to-chat.
# If left empty, we build one from WHATSAPP_NUMBER automatically.
WHATSAPP_LINK=

# ── FRONTEND (set in Netlify, exposed to client via VITE_ prefix) ────────────
# NOT required in production — the netlify.toml redirect proxies /api/* to the
# function automatically. Only set this if the API is hosted elsewhere.
# VITE_API_URL=https://api.ulsesadesco.online
